---
import type { JsonLd } from '@/lib/structured-data';
import Analytics from '@/components/analytics.astro';
import Footer from '@/components/footer.astro';
import Header from '@/components/header.astro';
import Seo from './Seo.astro';
import '../styles/global.css';
// Fingerprinted URL of the critical display font (h1/hero — the LCP element).
// Preloaded below so the browser fetches it in parallel with the CSS instead of
// discovering it only after the stylesheet parses. `?url` returns the same hashed
// asset the @font-face in global.css resolves to, so there is no double download.
import bricolageLatinUrl from '@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  canonical?: string | undefined;
  image?: string | undefined;
  jsonLd?: JsonLd | JsonLd[] | undefined;
}

const { title, description, canonical, image, jsonLd } = Astro.props;

// A page may fill the `hero` slot. When it does, a decorative brume-field layer
// is painted BEHIND the hero — and up behind the floating pill — as an absolutely
// positioned element, never as the header's parent. Wrapping the header would
// bound its `position: sticky` to the hero's height, so it would unstick at the
// hero's bottom; keeping the header a direct child of <body> lets it stay stuck
// to the whole page. Pages without a hero (statuts, guides…) keep a white top.
const hasHero = Astro.slots.has('hero');
---

<!doctype html>
<html lang="fr">
  <head>
    <Seo
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      jsonLd={jsonLd}
    />
    <link
      rel="preload"
      href={bricolageLatinUrl}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col bg-background text-foreground">
    <Header />
    {
      hasHero ? (
        <div class="relative">
          {/* Decorative brume backdrop, painted as an absolute layer (never the
              header's parent — see comment above). `-top-16` ≈ the header's
              reserved height, so the gradient reaches the page top behind the
              floating pill; `bottom-0` snaps it to the hero's lower edge. */}
          <div class="brume-field pointer-events-none absolute inset-x-0 -top-16 bottom-0 -z-10" aria-hidden="true" />
          <slot name="hero" />
        </div>
      ) : null
    }
    <div class="flex flex-1 flex-col">
      <slot />
    </div>
    <Footer />
  </body>
</html>
