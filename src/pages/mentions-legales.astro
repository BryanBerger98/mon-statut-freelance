---
/**
 * Mentions légales — mandatory under the LCEN (Loi pour la Confiance dans
 * l'Économie Numérique, art. 6 III). Editor is a micro-entrepreneur (personne
 * physique) registered for VAT, so the page carries the entrepreneur's name,
 * professional (domiciliation) address, SIRET and intra-EU VAT number, plus the
 * host's full identification.
 */
import ContentLayout from '@/layouts/ContentLayout.astro';
import { breadcrumbLd } from '@/lib/structured-data';

const breadcrumbs = [{ label: 'Accueil', href: '/' }, { label: 'Mentions légales' }];

const jsonLd = breadcrumbLd([{ name: 'Accueil', url: new URL('/', Astro.site).href }, { name: 'Mentions légales' }]);
---

