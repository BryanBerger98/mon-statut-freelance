# Self-hosted Umami — cookieless analytics (visitor counts + top pages).
# Public, build-time-inlined values. Leave both UNSET to disable analytics:
# dev/preview builds then emit no tracking script.
#
# In production these come from GitHub Actions repository VARIABLES (not secrets),
# wired into the Build step — see .github/workflows/deploy.yml.

# URL of the Umami tracker script on your self-hosted instance.
PUBLIC_UMAMI_SRC="https://stats.mon-statut-freelance.fr/script.js"

# The website id Umami assigns when you add this site in its dashboard.
PUBLIC_UMAMI_WEBSITE_ID="00000000-0000-0000-0000-000000000000"
